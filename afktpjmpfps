-- LIST MANAGER
function refresh()
    for _,v in pairs(listFrame:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    for i,data in ipairs(savedData) do
        local row = Instance.new("Frame", listFrame)
        row.Size = UDim2.new(1,0,0,25)
        row.BackgroundColor3 = Color3.fromRGB(30,30,30)
        row.BorderSizePixel = 0
        
        local btn = Instance.new("TextButton", row)
        btn.Size = UDim2.new(0.6,0,1,0)
        btn.Text = " " .. data.name
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.TextColor3 = Color3.new(1,1,1)
        btn.BackgroundTransparency = 1
        btn.MouseButton1Click:Connect(function() tp(Vector3.new(data.x,data.y,data.z)) end)
        
        local del = Instance.new("TextButton", row)
        del.Size = UDim2.new(0.2,0,1,0)
        del.Position = UDim2.new(0.6,0,0,0)
        del.Text = "X"
        del.BackgroundColor3 = Color3.fromRGB(100, 30, 30)
        del.MouseButton1Click:Connect(function() table.remove(savedData,i) saveData() refresh() end)

        local ren = Instance.new("TextButton", row)
        ren.Size = UDim2.new(0.2,0,1,0)
        ren.Position = UDim2.new(0.8,0,0,0)
        ren.Text = "R"
        ren.BackgroundColor3 = Color3.fromRGB(40, 40, 80)
        ren.MouseButton1Click:Connect(function()
            isRenaming = true
            box.Text = ""
            box:CaptureFocus()
            box.PlaceholderText = "Enter New Name..."
            local con; con = box.FocusLost:Connect(function(e)
                if e and box.Text ~= "" then
                    savedData[i].name = box.Text
                    saveData() refresh()
                end
                isRenaming = false
                box.PlaceholderText = "Target Name + Enter"
                con:Disconnect()
            end)
        end)
    end
end

saveBtn.MouseButton1Click:Connect(function()
    if LP.Character then
        local p = LP.Character.HumanoidRootPart.Position
        table.insert(savedData,{name="Loc "..(#savedData+1), x=p.X, y=p.Y, z=p.Z})
        saveData() refresh()
    end
end)

