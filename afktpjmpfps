--// STORAGE
local folder = "/storage/emulated/0/Delta/Workspace/"
local file = folder .. "coords.json"
if not isfolder(folder) then makefolder(folder) end
local savedData = {}

local function loadData()
    if isfile(file) then
        local ok, res = pcall(function() return HttpService:JSONDecode(readfile(file)) end)
        if ok and type(res) == "table" then savedData = res end
    end
end
local function saveData() writefile(file, HttpService:JSONEncode(savedData)) end
loadData()

--// OPTIMIZER FUNCTION (Anti-Lag)
local function setOptimization(enable)
    if enable then
        -- Mengurangi beban render tapi tetap menjaga tampilan dasar
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        Lighting.GlobalShadows = false
        Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
        for _, v in pairs(game:GetDescendants()) do
            if v:IsA("PostEffect") then v.Enabled = false end
        end
    else
        -- Mengembalikan ke settingan User (Bagus untuk Foto)
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        Lighting.GlobalShadows = true
        for _, v in pairs(game:GetDescendants()) do
            if v:IsA("PostEffect") then v.Enabled = true end
        end
    end
end

--// GLOBAL STATE
local isRenaming = false
local flying = false
local flySpeed = 50
local ctrl = {q = 0, e = 0}
local bv, bg

--// PLAYER FINDER & TP
local function getPlayer(str)
    str = str:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(str) or p.DisplayName:lower():find(str) then return p end
    end
end

local function tp(pos)
    local c = LP.Character
    if c and c:FindFirstChild("HumanoidRootPart") then
        c.HumanoidRootPart.CFrame = (typeof(pos) == "CFrame" and pos or CFrame.new(pos))
    end
end

